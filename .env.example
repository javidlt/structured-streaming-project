# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=transactions
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=streaming123
NEO4J_DATABASE=neo4j

# --- Producer ---
PRODUCER_INTERVAL_MS=200
PRODUCER_LOG_EVERY=50
PRODUCER_NUM_CUSTOMERS=1000
PRODUCER_NUM_MERCHANTS=200

# --- Consumer (Spark) ---
SPARK_APP_NAME=streaming-transactions
SPARK_CHECKPOINT_DIR=./checkpoints
SPARK_WATERMARK=1 minute
SPARK_WINDOW_DURATION=1 minute

# --- Orchestrator ---
DASHBOARD_REFRESH_SECONDS=3
HEALTHCHECK_TIMEOUT_SECONDS=180
